# ============================================
# NEXTAUTH CONFIGURATION (CRITICAL)
# ============================================
# For localhost development:
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here"

# For production on Vercel:
# Set NEXTAUTH_URL in your Vercel dashboard to your production URL
# Example: https://your-app.vercel.app
# 
# The app will automatically detect VERCEL_URL in production,
# but explicitly setting NEXTAUTH_URL takes precedence.

# ============================================
# DATABASE
# ============================================
NEXT_PUBLIC_DATABASE_URL="postgresql://user:password@host/database?sslmode=require&channel_binding=require"

# ============================================
# YOUTUBE API
# ============================================
YOUTUBE_API_KEYS="key1,key2,key3,key4"

# ============================================
# AI APIs
# ============================================
GEMINI_API_KEY="your-gemini-api-key"
NEXT_PUBLIC_GEMINI_API_KEY="your-gemini-api-key"

GROQ_API_KEY="your-groq-api-key"
GROQ_API_KEY_2="your-groq-api-key-2"

# ============================================
# CLERK AUTHENTICATION (Optional)
# ============================================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"

# ============================================
# APPLICATION CONFIG
# ============================================
NEXT_PUBLIC_INTERVIEW_QUESTION_COUNT=10
NEXT_PUBLIC_INFORMATION="Enable your Webcam and Microphone to start your AI-Generated Mock Interview..."
NEXT_PUBLIC_QUESTION_NOTE="Each interview includes 10 AI-generated questions..."
